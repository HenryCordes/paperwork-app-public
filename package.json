{
  "license": "UNLICENSED",
  "name": "paperwork",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test.e2e": "cypress run",
    "test.unit": "vitest --run",
    "test.unit.watch": "vitest",
    "test.unit.coverage": "vitest --run --coverage",
    "lint": "eslint",
    "run:ios": "npx cap sync && tsc && vite build && ionic capacitor run ios --external --open --prod",
    "run:android": "npx cap sync && tsc && vite build && ionic capacitor run android -l --external --open",
    "build:android:prod": "rm -rf android/app/build dist www && tsc && vite build && npx cap copy android && npx cap sync android && cd android && ./gradlew clean && cd .. && ionic capacitor build android --no-open --no-inline-style --no-mixed",
    "run:web": "npx cap sync && tsc && vite build && vite",
    "update-version": "node ./scripts/update-version.js",
    "typecheck": "tsc --noEmit",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": "eslint --fix"
  },
  "dependencies": {
    "@aparajita/capacitor-biometric-auth": "^9.0.0",
    "@capacitor-community/image-to-text": "^7.0.0",
    "@capacitor-firebase/messaging": "^7.3.1",
    "@capacitor/android": "^7.2.0",
    "@capacitor/app": "7.0.1",
    "@capacitor/camera": "^7.0.1",
    "@capacitor/core": "7.2.0",
    "@capacitor/filesystem": "^7.1.4",
    "@capacitor/haptics": "7.0.1",
    "@capacitor/ios": "^7.2.0",
    "@capacitor/keyboard": "7.0.1",
    "@capacitor/push-notifications": "^7.0.3",
    "@capacitor/status-bar": "7.0.1",
    "@capawesome/capacitor-badge": "^7.0.1",
    "@emotion/core": "^11.0.0",
    "@emotion/eslint-plugin": "^11.12.0",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@ionic/react": "^8.5.0",
    "@ionic/react-router": "^8.5.0",
    "@jcesarmobile/capacitor-ocr": "^0.0.1",
    "@tanstack/react-query": "^5.76.1",
    "@tinymce/tinymce-react": "^6.2.1",
    "@types/react-router": "^5.1.20",
    "@types/react-router-dom": "^5.3.3",
    "axios": "^1.9.0",
    "capacitor-document-scanner": "^2.0.0",
    "capacitor-secure-storage-plugin": "^0.11.0",
    "chart.js": "^4.5.0",
    "date-fns": "^4.1.0",
    "dompurify": "^3.2.5",
    "firebase": "^11.10.0",
    "ionicons": "^7.4.0",
    "react": "19.0.0",
    "react-chartjs-2": "^5.3.0",
    "react-dom": "19.0.0",
    "react-router": "^5.3.4",
    "react-router-dom": "^5.3.4",
    "tinymce": "^7.9.1"
  },
  "devDependencies": {
    "@capacitor/cli": "7.2.0",
    "@testing-library/dom": ">=7.21.4",
    "@testing-library/jest-dom": "^5.16.5",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.4.3",
    "@types/react": "19.0.10",
    "@types/react-dom": "19.0.4",
    "@vitejs/plugin-legacy": "^5.0.0",
    "@vitejs/plugin-react": "^4.0.1",
    "@vitest/coverage-v8": "^0.34.6",
    "cypress": "^13.5.0",
    "eslint": "^9.20.1",
    "eslint-plugin-react": "^7.32.2",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^22.1.0",
    "lint-staged": "^17.0.7",
    "terser": "^5.4.0",
    "typescript": "^5.1.6",
    "typescript-eslint": "^8.24.0",
    "vite": "~5.2.0",
    "vitest": "^0.34.6"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.40.2"
  },
  "overrides": {
    "capacitor-document-scanner": {
      "@capacitor/core": "^7.0.0",
      "@capacitor/ios": "^7.0.0",
      "@capacitor/android": "^7.0.0"
    },
    "@emotion/eslint-plugin": {
      "eslint": "^9.0.0"
    }
  },
  "description": "Paperwork a dutch bookeeping and receipt scanner app"
}
